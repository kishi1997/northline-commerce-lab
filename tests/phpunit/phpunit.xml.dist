<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.5/phpunit.xsd"
         bootstrap="bootstrap.php"
         colors="true"
         cacheDirectory="../../.phpunit.cache">
  <testsuites>
    <testsuite name="Northline Commerce Rules unit tests">
      <directory>.</directory>
    </testsuite>
  </testsuites>
  <source>
    <include>
      <directory>../../wp-content/plugins/northline-commerce-rules/includes</directory>
    </include>
  </source>
</phpunit>
